{
  "compilerOptions": {
    "module": "ES2022", // Compile to CommonJS
    "target": "ES2024", // Set target to ES6 (or higher)
    "moduleResolution": "node", // Helps TypeScript understand Node.js module resolution
    "esModuleInterop": true, // Ensures compatibility with CommonJS modules
    "outDir": "./dist", // Output directory
    "rootDir": "./src", // Source directory to include Shared
    "strict": true, // Optional, for strict type checking
    "resolveJsonModule": true // If you need to import JSON files
  },
  "include": ["src/BackEnd/**/*", "src/Shared/**/*"], // Include BackEnd and Shared files
  "exclude": ["node_modules", "src/FrontEnd"] // Exclude node_modules and FrontEnd
}
