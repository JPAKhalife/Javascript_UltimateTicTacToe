{
  "compilerOptions": {
    "module": "esnext", // Compile to ES Modules
    "target": "es6", // Set target to ES6 (or higher)
    "moduleResolution": "node", // Helps TypeScript understand module resolution
    "esModuleInterop": true, // Ensures compatibility with CommonJS modules if needed
    "outDir": "./dist", // Output directory
    "rootDir": "./src", // Source directory to include Shared
    "strict": true // Optional, for strict type checking
  },
  "include": ["src/FrontEnd/**/*.ts", "src/Shared/**/*"], // Include FrontEnd and Shared files
  "exclude": ["node_modules", "src/server.ts", "src/BackEnd"] // Exclude node_modules and BackEnd
}
